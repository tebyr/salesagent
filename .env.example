# ========================================
# SALES AGENT SAAS - CONFIGURACION
# ========================================

# --- APP ---
APP_NAME="Sales Agent SaaS"
APP_ENV=development  # development | staging | production
APP_SECRET_KEY=your-secret-key-here-change-in-production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- DATABASE ---
DATABASE_URL=postgresql+asyncpg://salesagent:password@localhost:5432/salesagent_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- REDIS ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- IA (LiteLLM — soporta Anthropic, OpenAI, Groq, Google, Mistral y más) ---
# Solo necesitas la key del proveedor que vayas a usar.
# Cambia los AI_MODEL_* de abajo para cambiar de proveedor sin tocar código.

# Anthropic (producción recomendada)
ANTHROPIC_API_KEY=
# OpenAI (alternativa)
OPENAI_API_KEY=
# Groq (RECOMENDADO para desarrollo/pruebas — tier gratuito generoso)
# Obtener key gratis en: console.groq.com
GROQ_API_KEY=

# Modelos por nivel de complejidad — descomentar el bloque del proveedor a usar
# --- Groq (pruebas/desarrollo — GRATIS) ---
AI_MODEL_SIMPLE=groq/llama-3.1-8b-instant     # Notificaciones rutinarias
AI_MODEL_STANDARD=groq/llama-3.1-70b-versatile # Recomendaciones y analisis
AI_MODEL_COMPLEX=groq/llama-3.1-70b-versatile  # Reportes gerenciales
# --- Anthropic (producción) ---
# AI_MODEL_SIMPLE=claude-haiku-4-5
# AI_MODEL_STANDARD=claude-sonnet-4-6
# AI_MODEL_COMPLEX=claude-opus-4-6
# --- OpenAI (alternativa) ---
# AI_MODEL_SIMPLE=gpt-4o-mini
# AI_MODEL_STANDARD=gpt-4o
# AI_MODEL_COMPLEX=gpt-4o

# --- WHATSAPP BUSINESS API (Meta Cloud API) ---
# Cada tenant tiene sus propias credenciales de WhatsApp
# Estas son las credenciales del sistema para el webhook
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token-here
WHATSAPP_APP_SECRET=your-app-secret-here

# --- EMAIL (SendGrid) ---
SENDGRID_API_KEY=your-sendgrid-api-key-here
EMAIL_FROM=noreply@yoursaas.com
EMAIL_FROM_NAME="Sales Agent"

# --- AWS ---
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=salesagent-files

# --- SEGURIDAD ---
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Llave de encripcion simetrica Fernet para valores sensibles en BD (tokens WA, etc.)
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANTE: Una vez generada y con datos en BD, NO cambiar esta llave o los tokens guardados
# seran ilegibles. Rotar con un proceso de re-encripcion controlado.
ENCRYPTION_KEY=your-fernet-key-here

# --- LIMITES DE COSTOS (por tenant/mes en USD) ---
AI_COST_ALERT_THRESHOLD_USD=50.0
AI_COST_HARD_LIMIT_USD=100.0
WHATSAPP_DAILY_MESSAGE_LIMIT=1000

# --- SENTRY (Monitoreo de errores) ---
SENTRY_DSN=your-sentry-dsn-here

# --- CONFIGURACION GENERAL ---
DEFAULT_TIMEZONE=America/Bogota
DEFAULT_LANGUAGE=es
BUSINESS_HOURS_START=6  # 6:00 AM
BUSINESS_HOURS_END=21   # 9:00 PM
