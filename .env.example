# ========================================
# SALES AGENT SAAS - CONFIGURACION
# ========================================

# --- APP ---
APP_NAME="Sales Agent SaaS"
APP_ENV=development  # development | staging | production
APP_SECRET_KEY=your-secret-key-here-change-in-production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- DATABASE ---
DATABASE_URL=postgresql+asyncpg://salesagent:password@localhost:5432/salesagent_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- REDIS ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- ANTHROPIC (Claude AI) ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Modelos por nivel de complejidad (control de costos)
AI_MODEL_SIMPLE=claude-haiku-4-5        # Notificaciones rutinarias
AI_MODEL_STANDARD=claude-sonnet-4-6     # Recomendaciones y analisis
AI_MODEL_COMPLEX=claude-opus-4-6        # Reportes gerenciales y proyecciones

# --- WHATSAPP BUSINESS API (Meta Cloud API) ---
# Cada tenant tiene sus propias credenciales de WhatsApp
# Estas son las credenciales del sistema para el webhook
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token-here
WHATSAPP_APP_SECRET=your-app-secret-here

# --- EMAIL (SendGrid) ---
SENDGRID_API_KEY=your-sendgrid-api-key-here
EMAIL_FROM=noreply@yoursaas.com
EMAIL_FROM_NAME="Sales Agent"

# --- AWS ---
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=salesagent-files

# --- SEGURIDAD ---
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- LIMITES DE COSTOS (por tenant/mes en USD) ---
AI_COST_ALERT_THRESHOLD_USD=50.0
AI_COST_HARD_LIMIT_USD=100.0
WHATSAPP_DAILY_MESSAGE_LIMIT=1000

# --- SENTRY (Monitoreo de errores) ---
SENTRY_DSN=your-sentry-dsn-here

# --- CONFIGURACION GENERAL ---
DEFAULT_TIMEZONE=America/Bogota
DEFAULT_LANGUAGE=es
BUSINESS_HOURS_START=6  # 6:00 AM
BUSINESS_HOURS_END=21   # 9:00 PM
